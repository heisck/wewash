# ════════════════════════════════════════════════════════════════
# WeWash — environment template
# Copy to .env (local) or paste keys into Vercel → Project → Settings → Environment Variables
#   cp .env.example .env
# Never commit real secrets.
# ════════════════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME=WeWash
# Optional (local docker / scripts)
APP_PORT=3000

# ── Database (PostgreSQL via Prisma) ───────────────────────────
# Local Docker (docker-compose.yml):
#   DATABASE_URL=postgresql://wewash:wewash_password@localhost:5432/wewash
#   DIRECT_URL=postgresql://wewash:wewash_password@localhost:5432/wewash
#
# Production (Neon / Supabase / etc.) — NOT localhost:
#   DATABASE_URL = pooled connection string (app queries)
#   DIRECT_URL   = non-pooled / direct string (Prisma migrations)
#   If you only have one URL, set BOTH to the same value.
DATABASE_URL=postgresql://wewash:wewash_password@localhost:5432/wewash
DIRECT_URL=postgresql://wewash:wewash_password@localhost:5432/wewash
DATABASE_POOL_SIZE=10

# ── Redis (BullMQ jobs / cache / OTP cooldowns) ────────────────
# Local Docker: redis://localhost:6379
# Upstash: MUST use rediss:// (TLS, double-s). Plain redis:// will ECONNRESET.
#   Console → Redis → Connect → copy "Redis URL" (rediss://default:…@….upstash.io:6379)
REDIS_URL=redis://localhost:6379

# ── Auth (Better Auth) ─────────────────────────────────────────
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-long-random-string-min-16-chars
# Must match the public site URL in production (e.g. https://wewash.vercel.app)
BETTER_AUTH_URL=http://localhost:3000

# ── Google OAuth (optional — leave empty to hide Google sign-in) ─
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Arkesel SMS / OTP ──────────────────────────────────────────
ARKESEL_API_KEY=your_arkesel_api_key
ARKESEL_SENDER_ID=WeWash
ARKESEL_BASE_URL=https://sms.arkesel.com
# true = sandbox (API returns success but SMS is NOT delivered / not in live history)
# false = real SMS (uses balance; shows in Arkesel dashboard)
ARKESEL_SANDBOX=false

# ── Email (Gmail SMTP — password reset / email OTP) ────────────
# Use a Google App Password (NOT your normal Gmail password):
#   Google Account → Security → 2-Step Verification → App passwords
#   Create one named "WeWash" and paste the 16-char password below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
# Optional display From (defaults to SMTP_USER)
SMTP_FROM="WeWash <your.email@gmail.com>"

# ── Cloudinary (optional — uploads / images) ───────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ── Web Push (optional) ────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@wewash.app
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ── Vercel Cron auth (optional but recommended in production) ──
# Vercel sends: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# ── Public contact fallbacks (admin can override in Settings) ──
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_CONTACT_EMAIL=

# ── Observability (optional) ───────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
LOG_LEVEL=info
