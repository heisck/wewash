// ─── WeWash Prisma Schema ─────────────────────────────────────
// Production-ready schema for washing machine management system
// ───────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  ENUMS                                                        ║
// ╚═══════════════════════════════════════════════════════════════╝

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STUDENT
}

enum MachineStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  FAULTY
  DECOMMISSIONED
}

enum FaultSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FaultStatus {
  REPORTED
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  CLOSED
  WONT_FIX
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
  CARD
  OTHER
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
  RENEWED
}

enum NotificationType {
  SMS
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  FAILED
  RETRYING
}

enum TransferReason {
  RELOCATION
  MAINTENANCE
  DECOMMISSION
  REPLACEMENT
  REBALANCING
  OTHER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  AUTH MODELS (Better Auth compatible)                          ║
// ╚═══════════════════════════════════════════════════════════════╝

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  phone         String?   @unique
  role          UserRole  @default(STUDENT)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  sessions      Session[]
  accounts      Account[]
  student       Student?
  auditLogs     AuditLog[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  DOMAIN MODELS                                                ║
// ╚═══════════════════════════════════════════════════════════════╝

model Hall {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique // e.g., "ATL" for Atlantic Hall
  location    String?
  description String?
  capacity    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime? // Soft delete

  // Relations
  rooms       Room[]
  machines    Machine[]

  @@index([name])
  @@index([code])
  @@index([deletedAt])
  @@map("halls")
}

model Room {
  id          String   @id @default(cuid())
  number      String   // Room number e.g., "101", "A12"
  floor       Int?
  capacity    Int      @default(1) // How many students
  hallId      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  hall              Hall              @relation(fields: [hallId], references: [id], onDelete: Cascade)
  students          Student[]
  machineSchedules  MachineSchedule[]

  @@unique([hallId, number])
  @@index([hallId])
  @@index([deletedAt])
  @@map("rooms")
}

model Student {
  id              String   @id @default(cuid())
  studentId       String   @unique // University student ID
  firstName       String
  lastName        String
  phone           String
  email           String?
  roomId          String?
  userId          String?  @unique
  emergencyContact String?
  emergencyPhone  String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relations
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  room          Room?         @relation(fields: [roomId], references: [id], onDelete: SetNull)
  payments      Payment[]
  faultReports  FaultReport[]
  contracts     Contract[]
  waitingList   WaitingList[]

  @@index([studentId])
  @@index([roomId])
  @@index([userId])
  @@index([phone])
  @@index([deletedAt])
  @@map("students")
}

model Machine {
  id              String        @id @default(cuid())
  serialNumber    String        @unique
  brand           String?
  model           String?
  purchaseDate    DateTime?
  warrantyExpiry  DateTime?
  status          MachineStatus @default(ACTIVE)
  hallId          String?
  notes           String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  // Relations
  hall              Hall?              @relation(fields: [hallId], references: [id], onDelete: SetNull)
  faultReports      FaultReport[]
  maintenanceLogs   MaintenanceLog[]
  transferLogs      TransferLog[]
  machineSchedules  MachineSchedule[]
  contracts         Contract[]

  @@index([serialNumber])
  @@index([status])
  @@index([hallId])
  @@index([deletedAt])
  @@map("machines")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  MACHINE ROTATION SCHEDULE                                    ║
// ║  1 machine rotates across up to 7 rooms on a daily schedule   ║
// ║  Admin-configurable: which rooms, what time, what order       ║
// ╚═══════════════════════════════════════════════════════════════╝

model MachineSchedule {
  id              String    @id @default(cuid())
  machineId       String
  roomId          String
  dayOfWeek       DayOfWeek
  startTime       String    // "08:00" — 24h format
  endTime         String    // "08:00" next day
  orderIndex      Int       // 0-6, determines rotation order
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)
  room    Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([machineId, dayOfWeek])          // One machine can only be in 1 room per day
  @@unique([roomId, dayOfWeek])             // One room can only have 1 machine per day
  @@index([machineId])
  @@index([roomId])
  @@index([dayOfWeek])
  @@map("machine_schedules")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  FINANCIAL MODELS                                             ║
// ╚═══════════════════════════════════════════════════════════════╝

model Payment {
  id              String        @id @default(cuid())
  studentId       String
  contractId      String?
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("GHS")
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  reference       String?       @unique // External reference / receipt number
  description     String?
  paidAt          DateTime?
  dueDate         DateTime?
  receiptUrl      String?
  notes           String?
  recordedBy      String?       // Admin user ID who recorded this
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  // Relations
  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  contract Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([contractId])
  @@index([status])
  @@index([paidAt])
  @@index([dueDate])
  @@index([deletedAt])
  @@map("payments")
}

model Contract {
  id              String         @id @default(cuid())
  studentId       String
  machineId       String
  status          ContractStatus @default(DRAFT)
  startDate       DateTime
  endDate         DateTime
  monthlyAmount   Decimal        @db.Decimal(10, 2)
  currency        String         @default("GHS")
  terms           String?        @db.Text
  documentUrl     String?       // PDF contract link
  signedAt        DateTime?
  terminatedAt    DateTime?
  terminationNote String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  // Relations
  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  machine  Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([studentId])
  @@index([machineId])
  @@index([status])
  @@index([endDate])
  @@index([deletedAt])
  @@map("contracts")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  FAULT & MAINTENANCE                                          ║
// ╚═══════════════════════════════════════════════════════════════╝

model FaultReport {
  id              String        @id @default(cuid())
  machineId       String
  reportedById    String        // Student ID
  title           String
  description     String        @db.Text
  severity        FaultSeverity @default(MEDIUM)
  status          FaultStatus   @default(REPORTED)
  imageUrls       String[]      // Array of image URLs
  resolution      String?       @db.Text
  resolvedAt      DateTime?
  resolvedBy      String?       // Admin/technician user ID
  estimatedCost   Decimal?      @db.Decimal(10, 2)
  actualCost      Decimal?      @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  // Relations
  machine    Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)
  reportedBy Student @relation(fields: [reportedById], references: [id], onDelete: Cascade)

  @@index([machineId])
  @@index([reportedById])
  @@index([status])
  @@index([severity])
  @@index([deletedAt])
  @@map("fault_reports")
}

model MaintenanceLog {
  id              String   @id @default(cuid())
  machineId       String
  type            String   // "scheduled", "unscheduled", "inspection"
  description     String   @db.Text
  performedBy     String?  // Admin/technician name
  cost            Decimal? @db.Decimal(10, 2)
  scheduledDate   DateTime?
  completedDate   DateTime?
  nextDueDate     DateTime?
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId])
  @@index([scheduledDate])
  @@index([nextDueDate])
  @@map("maintenance_logs")
}

model TransferLog {
  id              String         @id @default(cuid())
  machineId       String
  fromHallId      String?
  fromRoomInfo    String?        // "Room 101" — kept as text for history
  toHallId        String?
  toRoomInfo      String?
  reason          TransferReason
  notes           String?
  transferredBy   String?        // Admin user ID
  transferredAt   DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId])
  @@index([transferredAt])
  @@map("transfer_logs")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  NOTIFICATIONS                                                ║
// ╚═══════════════════════════════════════════════════════════════╝

model NotificationLog {
  id              String             @id @default(cuid())
  type            NotificationType
  recipient       String             // Phone number or email
  subject         String?
  message         String             @db.Text
  status          NotificationStatus @default(PENDING)
  provider        String             @default("arkesel") // "arkesel", "smtp"
  providerId      String?            // Arkesel message ID
  errorMessage    String?
  retryCount      Int                @default(0)
  maxRetries      Int                @default(3)
  nextRetryAt     DateTime?
  sentAt          DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([recipient])
  @@index([status])
  @@index([provider])
  @@index([nextRetryAt])
  @@index([createdAt])
  @@map("notification_logs")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  WAITING LIST                                                 ║
// ╚═══════════════════════════════════════════════════════════════╝

model WaitingList {
  id          String   @id @default(cuid())
  studentId   String
  hallId      String?
  priority    Int      @default(0) // Higher = more priority
  notes       String?
  isActive    Boolean  @default(true)
  fulfilledAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([isActive])
  @@index([priority])
  @@map("waiting_lists")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  AUDIT LOGGING                                                ║
// ╚═══════════════════════════════════════════════════════════════╝

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String   // "CREATE", "UPDATE", "DELETE", "LOGIN", etc.
  entity      String   // "Machine", "Student", "Payment", etc.
  entityId    String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  SYSTEM CONFIG (Admin-configurable settings)                  ║
// ╚═══════════════════════════════════════════════════════════════╝

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  group     String   @default("general") // "general", "schedule", "notifications", "payments"
  label     String?  // Human-readable label
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
  @@map("system_configs")
}
