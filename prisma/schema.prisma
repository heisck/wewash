// ─── WeWash Prisma Schema ─────────────────────────────────────
// Production-ready schema for washing machine management system
// ───────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  ENUMS                                                        ║
// ╚═══════════════════════════════════════════════════════════════╝

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STUDENT
}

enum MachineStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  FAULTY
  DECOMMISSIONED
}

enum FaultSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FaultStatus {
  REPORTED
  ACKNOWLEDGED
  IN_PROGRESS
  RESOLVED
  CLOSED
  WONT_FIX
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK_TRANSFER
  CARD
  OTHER
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
  RENEWED
}

enum NotificationType {
  SMS
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  FAILED
  RETRYING
}

enum TransferReason {
  RELOCATION
  MAINTENANCE
  DECOMMISSION
  REPLACEMENT
  REBALANCING
  OTHER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum WashSessionStatus {
  IN_USE
  RETURNED
  EXPIRED
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  AUTH MODELS (Better Auth compatible)                          ║
// ╚═══════════════════════════════════════════════════════════════╝

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  emailVerified       Boolean   @default(false)
  image               String?
  // Better Auth phoneNumber plugin fields
  phoneNumber         String?   @unique
  phoneNumberVerified Boolean   @default(false)
  // Domain convenience (kept for existing services; prefer phoneNumber for auth)
  phone               String?   @unique
  role                UserRole  @default(STUDENT)
  isActive            Boolean   @default(true)
  /// Student prefs — SMS rotation/payment alerts (critical 2h SMS still may apply)
  notifySms           Boolean   @default(true)
  notifyEmail         Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  sessions          Session[]
  accounts          Account[]
  student           Student?
  auditLogs         AuditLog[]
  pushSubscriptions PushSubscription[]

  @@index([email])
  @@index([phone])
  @@index([phoneNumber])
  @@index([role])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  DOMAIN MODELS                                                ║
// ╚═══════════════════════════════════════════════════════════════╝

model Hall {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique // e.g., "ATL" for Atlantic Hall
  location    String?
  description String?
  capacity    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime? // Soft delete

  // Relations
  rooms          Room[]
  machines       Machine[]
  studentGroups  StudentGroup[]

  @@index([name])
  @@index([code])
  @@index([deletedAt])
  @@map("halls")
}

/**
 * A cohort of students on the same hostel floor/block.
 * Create groups after hostels exist; then add students to a group
 * and type their room number (no room dropdown).
 */
model StudentGroup {
  id          String   @id @default(cuid())
  name        String // e.g. "Block A · Floor 2"
  hallId      String
  floor       String // "Ground", "1", "2"…
  block       String // "A", "Block B"…
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  hall     Hall      @relation(fields: [hallId], references: [id], onDelete: Cascade)
  students Student[]

  @@unique([hallId, floor, block, name])
  @@index([hallId])
  @@index([floor])
  @@index([block])
  @@index([deletedAt])
  @@map("student_groups")
}

model Room {
  id          String   @id @default(cuid())
  number      String   // Room number e.g., "101", "A12"
  block       String?  // e.g. "Block A"
  floor       Int?
  section     String?  // e.g. "North wing"
  capacity    Int      @default(1) // Number of occupants
  hallId      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  // Relations
  hall              Hall              @relation(fields: [hallId], references: [id], onDelete: Cascade)
  students          Student[]
  machineSchedules  MachineSchedule[]
  washSessions      WashSession[]

  @@unique([hallId, number])
  @@index([hallId])
  @@index([deletedAt])
  @@map("rooms")
}

model Student {
  id              String   @id @default(cuid())
  studentId       String   @unique // University student ID
  indexNumber     String?  // Index number if applicable
  firstName       String
  lastName        String
  phone           String   // Primary phone
  secondaryPhone  String?
  whatsapp        String?
  email           String?
  roomId          String?
  /// Free-typed room label shown on roster (e.g. "12B"); Room row is upserted for schedules
  roomNumber      String?
  groupId         String?
  userId          String?  @unique
  weeklyAmount    Decimal  @default(0) @db.Decimal(10, 2) // Weekly subscription fee
  emergencyContact String?
  emergencyPhone  String?
  profileImageUrl String?
  documentUrls    String[] @default([])
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  // Relations
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  room          Room?         @relation(fields: [roomId], references: [id], onDelete: SetNull)
  group         StudentGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  payments      Payment[]
  faultReports  FaultReport[]
  contracts     Contract[]
  waitingList   WaitingList[]
  washSessions  WashSession[]

  @@index([studentId])
  @@index([roomId])
  @@index([groupId])
  @@index([userId])
  @@index([phone])
  @@index([deletedAt])
  @@map("students")
}

model Machine {
  id               String        @id @default(cuid())
  serialNumber     String        @unique // Machine ID / serial
  name             String?       // Display name
  code             String?       @unique // e.g. "WeWash W1"
  qrToken          String?       @unique // Opaque token embedded in the machine's printed QR code
  brand            String?
  model            String?
  capacityKg       Float?        // Capacity in kg
  machineType      String?       // e.g. "Front load", "Top load"
  purchaseDate     DateTime?
  installationDate DateTime?
  warrantyExpiry   DateTime?
  status           MachineStatus @default(ACTIVE)
  hallId           String?
  notes            String?
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  // Relations
  hall              Hall?              @relation(fields: [hallId], references: [id], onDelete: SetNull)
  faultReports      FaultReport[]
  maintenanceLogs   MaintenanceLog[]
  transferLogs      TransferLog[]
  machineSchedules  MachineSchedule[]
  contracts         Contract[]
  washSessions      WashSession[]

  @@index([serialNumber])
  @@index([qrToken])
  @@index([status])
  @@index([hallId])
  @@index([deletedAt])
  @@map("machines")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  MACHINE ROTATION SCHEDULE                                    ║
// ║  1 machine rotates across up to 7 rooms on a daily schedule   ║
// ║  Admin-configurable: which rooms, what time, what order       ║
// ╚═══════════════════════════════════════════════════════════════╝

model MachineSchedule {
  id              String    @id @default(cuid())
  machineId       String
  roomId          String
  dayOfWeek       DayOfWeek
  startTime       String    // "08:00" — 24h format
  endTime         String    // "08:00" next day
  orderIndex      Int       // 0-6, determines rotation order
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)
  room    Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([machineId, dayOfWeek])          // One machine can only be in 1 room per day
  @@unique([roomId, dayOfWeek])             // One room can only have 1 machine per day
  @@index([machineId])
  @@index([roomId])
  @@index([dayOfWeek])
  @@map("machine_schedules")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  WASH SESSIONS (QR scan → "machine in your hands")            ║
// ║  Created when a student scans the machine QR. Records which    ║
// ║  room the machine is in, how late they were vs the rotation    ║
// ║  window, and when it's due to move to the next room.           ║
// ╚═══════════════════════════════════════════════════════════════╝

model WashSession {
  id              String            @id @default(cuid())
  machineId       String
  roomId          String
  studentId       String?
  scheduleId      String? // MachineSchedule id for the day (nullable — schedule may change)
  scannedAt       DateTime          @default(now())
  expectedStartAt DateTime // When this room's rotation window opened
  dueBackAt       DateTime // When the machine must move to the next room
  minutesLate     Int? // Minutes after expectedStartAt that the scan happened
  endedAt         DateTime?
  status          WashSessionStatus @default(IN_USE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  machine Machine  @relation(fields: [machineId], references: [id], onDelete: Cascade)
  room    Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([machineId])
  @@index([roomId])
  @@index([studentId])
  @@index([status])
  @@index([scannedAt])
  @@map("wash_sessions")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  WEB PUSH SUBSCRIPTIONS (PWA notifications)                    ║
// ╚═══════════════════════════════════════════════════════════════╝

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  FINANCIAL MODELS                                             ║
// ╚═══════════════════════════════════════════════════════════════╝

model Payment {
  id                 String        @id @default(cuid())
  studentId          String
  contractId         String?
  amount             Decimal       @db.Decimal(10, 2) // Amount paid (legacy + primary)
  amountDue          Decimal?      @db.Decimal(10, 2)
  amountPaid         Decimal?      @db.Decimal(10, 2)
  currency           String        @default("GHS")
  method             PaymentMethod
  status             PaymentStatus @default(PENDING)
  reference          String?       @unique // External reference / receipt number
  momoTransactionId  String?       // Mobile Money transaction ID
  description        String?
  paidAt             DateTime?
  dueDate            DateTime?
  receiptUrl         String?       // Screenshot / receipt of payment confirmation
  notes              String?
  recordedBy         String?       // Admin user ID who recorded this
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?

  // Relations
  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  contract Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([contractId])
  @@index([status])
  @@index([paidAt])
  @@index([dueDate])
  @@index([deletedAt])
  @@map("payments")
}

model Contract {
  id              String         @id @default(cuid())
  studentId       String
  machineId       String
  status          ContractStatus @default(DRAFT)
  startDate       DateTime
  endDate         DateTime
  monthlyAmount   Decimal        @db.Decimal(10, 2)
  currency        String         @default("GHS")
  terms           String?        @db.Text
  documentUrl     String?       // PDF contract link
  signedAt        DateTime?
  terminatedAt    DateTime?
  terminationNote String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  // Relations
  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  machine  Machine   @relation(fields: [machineId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([studentId])
  @@index([machineId])
  @@index([status])
  @@index([endDate])
  @@index([deletedAt])
  @@map("contracts")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  FAULT & MAINTENANCE                                          ║
// ╚═══════════════════════════════════════════════════════════════╝

model FaultReport {
  id              String        @id @default(cuid())
  machineId       String
  reportedById    String        // Student ID
  title           String
  description     String        @db.Text
  severity        FaultSeverity @default(MEDIUM)
  status          FaultStatus   @default(REPORTED)
  imageUrls       String[]      // Array of image URLs
  resolution      String?       @db.Text
  resolvedAt      DateTime?
  resolvedBy      String?       // Admin/technician user ID
  estimatedCost   Decimal?      @db.Decimal(10, 2)
  actualCost      Decimal?      @db.Decimal(10, 2)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deletedAt       DateTime?

  // Relations
  machine    Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)
  reportedBy Student @relation(fields: [reportedById], references: [id], onDelete: Cascade)

  @@index([machineId])
  @@index([reportedById])
  @@index([status])
  @@index([severity])
  @@index([deletedAt])
  @@map("fault_reports")
}

model MaintenanceLog {
  id              String   @id @default(cuid())
  machineId       String
  type            String   // "scheduled", "unscheduled", "inspection"
  description     String   @db.Text
  performedBy     String?  // Admin/technician name
  cost            Decimal? @db.Decimal(10, 2)
  scheduledDate   DateTime?
  completedDate   DateTime?
  nextDueDate     DateTime?
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId])
  @@index([scheduledDate])
  @@index([nextDueDate])
  @@map("maintenance_logs")
}

model TransferLog {
  id              String         @id @default(cuid())
  machineId       String
  fromHallId      String?
  fromRoomInfo    String?        // "Room 101" — kept as text for history
  toHallId        String?
  toRoomInfo      String?
  reason          TransferReason
  notes           String?
  transferredBy   String?        // Admin user ID
  transferredAt   DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  machine Machine @relation(fields: [machineId], references: [id], onDelete: Cascade)

  @@index([machineId])
  @@index([transferredAt])
  @@map("transfer_logs")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  NOTIFICATIONS                                                ║
// ╚═══════════════════════════════════════════════════════════════╝

model NotificationLog {
  id              String             @id @default(cuid())
  type            NotificationType
  recipient       String             // Phone number or email
  subject         String?
  message         String             @db.Text
  status          NotificationStatus @default(PENDING)
  provider        String             @default("arkesel") // "arkesel", "smtp"
  providerId      String?            // Arkesel message ID
  errorMessage    String?
  retryCount      Int                @default(0)
  maxRetries      Int                @default(3)
  nextRetryAt     DateTime?
  sentAt          DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([recipient])
  @@index([status])
  @@index([provider])
  @@index([nextRetryAt])
  @@index([createdAt])
  @@map("notification_logs")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  WAITING LIST                                                 ║
// ╚═══════════════════════════════════════════════════════════════╝

model WaitingList {
  id          String   @id @default(cuid())
  studentId   String
  hallId      String?
  priority    Int      @default(0) // Higher = more priority
  notes       String?
  isActive    Boolean  @default(true)
  fulfilledAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([isActive])
  @@index([priority])
  @@map("waiting_lists")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  AUDIT LOGGING                                                ║
// ╚═══════════════════════════════════════════════════════════════╝

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String   // "CREATE", "UPDATE", "DELETE", "LOGIN", etc.
  entity      String   // "Machine", "Student", "Payment", etc.
  entityId    String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  DAY TRANSFER / SWAP REQUESTS                                 ║
// ╚═══════════════════════════════════════════════════════════════╝

enum DayTransferStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  CANCELLED
}

model DayTransferRequest {
  id              String            @id @default(cuid())
  studentId       String
  machineId       String
  fromDay         DayOfWeek
  toDay           DayOfWeek?
  swapRoomId      String?           // If swapping with another room
  reason          String?           @db.Text
  status          DayTransferStatus @default(PENDING)
  reviewedBy      String?
  reviewedAt      DateTime?
  adminNote       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([studentId])
  @@index([machineId])
  @@index([status])
  @@map("day_transfer_requests")
}

// ╔═══════════════════════════════════════════════════════════════╗
// ║  SYSTEM CONFIG (Admin-configurable settings)                  ║
// ╚═══════════════════════════════════════════════════════════════╝

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  group     String   @default("general") // "general", "schedule", "notifications", "payments"
  label     String?  // Human-readable label
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
  @@map("system_configs")
}
